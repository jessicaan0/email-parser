<Window
    x:Class="EmailParser.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:EmailParser.UI.Models"
    xmlns:converters="using:EmailParser.UI.Converters"
    Title="Email Parser">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="32,20,32,20" RowSpacing="16">
        <Grid.Resources>
            <converters:LogLevelToBrushConverter x:Key="LevelToBrush" />
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══ Row 0: Header ═══ -->
        <StackPanel Grid.Row="0" Spacing="2">
            <TextBlock Text="Email Parser"
                       Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Convert Outlook emails and .msg files to PDF with attachments"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- ═══ Row 1: Source Selection ═══ -->
        <StackPanel Grid.Row="1" Spacing="12"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

            <TextBlock Text="Email Source" Style="{StaticResource SubtitleTextBlockStyle}" />

            <StackPanel Orientation="Horizontal" Spacing="24">
                <RadioButton x:Name="OutlookRadio" Content="Outlook Folder"
                             GroupName="SourceType" Checked="SourceType_Checked" />
                <RadioButton x:Name="MsgRadio" Content=".msg File Directory"
                             GroupName="SourceType" Checked="SourceType_Checked" />
            </StackPanel>

            <!-- Outlook folder input -->
            <StackPanel x:Name="OutlookPanel" Spacing="4">
                <TextBlock Text="Folder path (e.g. 'Inbox' or 'Inbox/Projects')" FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBox Text="{x:Bind ViewModel.OutlookFolder, Mode=TwoWay}"
                         PlaceholderText="Enter Outlook folder path" />
            </StackPanel>

            <!-- .msg directory input -->
            <StackPanel x:Name="MsgPanel" Spacing="4" Visibility="Collapsed">
                <TextBlock Text="Directory containing .msg files" FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{x:Bind ViewModel.MsgDirectory, Mode=TwoWay}"
                             PlaceholderText="Select or type a directory path" />
                    <Button Grid.Column="1" Content="Browse..."
                            Click="BrowseMsgDir_Click" />
                </Grid>
            </StackPanel>
        </StackPanel>

        <!-- ═══ Row 2: Output Settings ═══ -->
        <StackPanel Grid.Row="2" Spacing="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

            <TextBlock Text="Output Settings" Style="{StaticResource SubtitleTextBlockStyle}" />

            <!-- Output Directory -->
            <StackPanel Spacing="4">
                <TextBlock Text="Output Directory — where converted PDFs are saved" FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{x:Bind ViewModel.OutputBaseDir, Mode=TwoWay}"
                             PlaceholderText="Output directory path" />
                    <Button Grid.Column="1" Content="Browse..."
                            Click="BrowseOutputDir_Click" />
                </Grid>
            </StackPanel>

            <!-- Reports Directory -->
            <StackPanel Spacing="4">
                <TextBlock Text="Reports Directory — where long-path Excel reports are saved (optional)" FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{x:Bind ViewModel.ReportsDir, Mode=TwoWay}"
                             PlaceholderText="Defaults to output directory if empty" />
                    <Button Grid.Column="1" Content="Browse..."
                            Click="BrowseReportsDir_Click" />
                </Grid>
            </StackPanel>

            <!-- Data Dictionary Directory -->
            <StackPanel Spacing="4">
                <TextBlock Text="Data Dictionary Directory — contains the Excel data dictionary (optional)" FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{x:Bind ViewModel.DataDictionaryDir, Mode=TwoWay}"
                             PlaceholderText="Defaults to output directory if empty" />
                    <Button Grid.Column="1" Content="Browse..."
                            Click="BrowseDictDir_Click" />
                </Grid>
            </StackPanel>
        </StackPanel>

        <!-- ═══ Row 3: Run button and status ═══ -->
        <Grid Grid.Row="3" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Style="{StaticResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.RunCommand}"
                    MinWidth="200" Height="40"
                    FontWeight="SemiBold">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE768;" FontSize="16" />
                    <TextBlock Text="Run Email Parser" />
                </StackPanel>
            </Button>
            <ProgressRing Grid.Column="1" IsActive="{x:Bind ViewModel.IsRunning, Mode=OneWay}"
                          Width="24" Height="24" />
            <TextBlock Grid.Column="2"
                       Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </Grid>

        <!-- ═══ Row 4: Progress bar ═══ -->
        <ProgressBar Grid.Row="4"
                     IsIndeterminate="{x:Bind ViewModel.IsProgressIndeterminate, Mode=OneWay}"
                     ShowError="{x:Bind ViewModel.IsProgressError, Mode=OneWay}" />

        <!-- ═══ Row 5: Log viewer ═══ -->
        <Grid Grid.Row="5" RowSpacing="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Log Output" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Grid.Column="1"
                           Text="{x:Bind ViewModel.LogEntries.Count, Mode=OneWay}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center" FontSize="12" />
            </Grid>

            <ListView x:Name="LogListView" Grid.Row="1"
                      ItemsSource="{x:Bind ViewModel.LogEntries, Mode=OneWay}"
                      SelectionMode="Extended"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="1" CornerRadius="8"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      Padding="4">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:LogEntry">
                        <Grid ColumnSpacing="8" Padding="4,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{x:Bind Timestamp}"
                                       FontFamily="Cascadia Code,Consolas,Courier New"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Top" />

                            <Border Grid.Column="1"
                                    Background="{x:Bind Level, Converter={StaticResource LevelToBrush}}"
                                    CornerRadius="4" Padding="6,1"
                                    VerticalAlignment="Top"
                                    MinWidth="32"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="{x:Bind Level}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center" />
                            </Border>

                            <TextBlock Grid.Column="2"
                                       Text="{x:Bind Message}"
                                       FontFamily="Cascadia Code,Consolas,Courier New"
                                       FontSize="12"
                                       TextWrapping="WrapWholeWords"
                                       IsTextSelectionEnabled="True"
                                       VerticalAlignment="Top" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- ═══ Row 6: Footer buttons ═══ -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" Spacing="8" Padding="0,4,0,0">
            <Button Click="OpenOutputFolder_Click" ToolTipService.ToolTip="Open output folder in Explorer">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE838;" FontSize="14" />
                    <TextBlock Text="Open Output Folder" />
                </StackPanel>
            </Button>
            <Button Click="OpenLogsFolder_Click" ToolTipService.ToolTip="Open logs folder in Explorer">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE8A5;" FontSize="14" />
                    <TextBlock Text="Open Logs Folder" />
                </StackPanel>
            </Button>
            <Button Click="ClearLog_Click" ToolTipService.ToolTip="Clear log output">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                    <TextBlock Text="Clear Log" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>
